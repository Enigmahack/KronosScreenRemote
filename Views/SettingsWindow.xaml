<Window x:Class="KronosScreenRemote.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Width="520" Height="620" MinHeight="480"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#FF1E1E1E"
        Foreground="White">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background"   Value="#FF3A3A3A"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="BorderBrush"  Value="#FF666666"/>
            <Setter Property="Padding"      Value="8 3"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background"   Value="#FF2A2A2A"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="BorderBrush"  Value="#FF555555"/>
            <Setter Property="Padding"      Value="4 2"/>
            <Setter Property="CaretBrush"   Value="White"/>
        </Style>
        <Style TargetType="ListView">
            <Setter Property="Background"   Value="#FF2A2A2A"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="BorderBrush"  Value="#FF555555"/>
        </Style>
        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background"   Value="#FF333333"/>
            <Setter Property="Foreground"   Value="#FFCCCCCC"/>
            <Setter Property="BorderBrush"  Value="#FF555555"/>
        </Style>
        <Style TargetType="Slider">
            <Setter Property="Foreground"   Value="#FF88AADD"/>
        </Style>

        <!-- Dark ListViewItem: readable selection + amber listening highlight -->
        <Style TargetType="ListViewItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="Bd"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                Padding="1 2">
                            <GridViewRowPresenter
                                Columns="{TemplateBinding GridView.ColumnCollection}"
                                Content="{TemplateBinding Content}"
                                VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF363636"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF1A4E6E"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#FF3A8FBF"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="#FF205A80"/>
                            </MultiTrigger>
                            <!-- Amber highlight while recording a new key -->
                            <DataTrigger Binding="{Binding IsListening}" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF4D3000"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#FFDD9933"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark TabItem -->
        <Style TargetType="TabItem">
            <Setter Property="Foreground"  Value="#FFCCCCCC"/>
            <Setter Property="Background"  Value="#FF252525"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
            <Setter Property="Padding"     Value="12 5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1 1 1 0"
                                Padding="{TemplateBinding Padding}"
                                Margin="0 0 2 0">
                            <ContentPresenter ContentSource="Header"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background"  Value="#FF2E2E2E"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background"  Value="#FF3A3A3A"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="#FF88AADD"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark TabControl -->
        <Style TargetType="TabControl">
            <Setter Property="Background"  Value="#FF2A2A2A"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TabPanel Grid.Row="0" IsItemsHost="True"
                                      Background="Transparent" Margin="0 0 0 -1"/>
                            <Border Grid.Row="1"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="1">
                                <ContentPresenter x:Name="PART_SelectedContentHost"
                                                  ContentSource="SelectedContent"
                                                  Margin="12"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" x:Name="SettingsTabControl">

            <!-- ── General ───────────────────────────────────────────────── -->
            <TabItem Header="General">
                <StackPanel Margin="0 4 0 0">
                    <CheckBox x:Name="ChkPromptQuit"   Content="Prompt before quitting"    Margin="0 0 0 10"
                              ToolTip="Shows a confirmation dialog before the app closes."/>
                    <CheckBox x:Name="ChkHideDataInput"  Content="Hide data input panel on startup"  Margin="0 0 0 10"
                              ToolTip="Hides the right-hand button panel at launch. Toggle from View → Hide Data Input."/>
                    <CheckBox x:Name="ChkHideValueInput" Content="Hide value input panel on startup" Margin="0 0 0 18"
                              ToolTip="Hides the left-hand slider panel at launch. Toggle from View → Hide Value Input."/>

                    <TextBlock Text="Screenshots" FontWeight="Bold" Foreground="#FF88AADD" Margin="0 0 0 8"/>
                    <Grid Margin="0 0 0 4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Output folder" VerticalAlignment="Center"
                                   ToolTip="Folder where quick-save screenshots are stored."/>
                        <TextBox   Grid.Column="1" x:Name="TxtScreenshotDir" Margin="0 0 6 0"
                                   ToolTip="Type a path directly, or click Browse to pick one. Leave empty to save next to the app executable."/>
                        <Button    Grid.Column="2" x:Name="BtnBrowseScreenshotDir" Content="Browse…"
                                   Padding="8 3" Click="OnBrowseScreenshotDir"
                                   ToolTip="Open a folder picker to choose the screenshot output folder."/>
                    </Grid>
                    <TextBlock Margin="0 0 0 18" Foreground="#FF888888" FontSize="11" TextWrapping="Wrap"
                               Text="Folder for quick-save screenshots. Leave empty to save next to the app executable."/>

                    <TextBlock Text="VGA output" FontWeight="Bold" Foreground="#FF88AADD" Margin="0 0 0 8"/>
                    <CheckBox x:Name="ChkVgaMirror" Content="Enable VGA mirror on connect" Margin="0 0 0 12"
                              ToolTip="Mirrors the Kronos touchscreen to the VGA output when connected. Applied immediately on OK."/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Screensaver timeout" VerticalAlignment="Center"
                                   ToolTip="Seconds of inactivity before the Kronos screensaver activates. 0 disables it. Applied immediately on OK."/>
                        <TextBox   Grid.Column="1" x:Name="TxtSsTimeout" Width="55" HorizontalAlignment="Left"
                                   ToolTip="Seconds of inactivity before the Kronos screensaver activates. 0 disables it."/>
                        <TextBlock Grid.Column="2" Text="seconds  (0 = disabled)" VerticalAlignment="Center"
                                   Margin="8 0 0 0" Foreground="#FF888888" FontSize="11"/>
                    </Grid>
                    <TextBlock Margin="0 6 0 0" Foreground="#FF888888" FontSize="11" TextWrapping="Wrap"
                               Text="VGA mirror and screensaver settings are applied immediately when you click OK while connected."/>

                    <Border Background="#FF444444" Margin="0 18 0 12" Height="1"/>
                    <TextBlock Text="Reset" FontWeight="Bold" Foreground="#FFCC4444" Margin="0 0 0 8"/>
                    <Button x:Name="BtnResetSettings"
                            Content="Reset All Settings"
                            Width="150"
                            HorizontalAlignment="Left"
                            Background="#FF3A1E1E"
                            Foreground="#FFDD6666"
                            BorderBrush="#FF883333"
                            Click="OnResetSettings"
                            ToolTip="Permanently deletes all settings, key maps, calibration, and customizations. Cannot be undone."/>
                    <TextBlock Margin="0 8 0 0" Foreground="#FF888888" FontSize="11" TextWrapping="Wrap"
                               Text="Removes all saved settings, key mappings, calibration data, and other customizations. The app returns to its default state. This cannot be undone."/>
                </StackPanel>
            </TabItem>

            <!-- ── Connection ───────────────────────────────────────────── -->
            <TabItem Header="Connection">
                <StackPanel>
                    <Grid Margin="0 4 0 0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Kronos IP address" VerticalAlignment="Center"
                                   ToolTip="IP address of the Kronos. Typically 192.168.100.15 over USB, or a DHCP address when connected via a router."/>
                        <TextBox   Grid.Row="0" Grid.Column="1" x:Name="TxtHost"
                                   ToolTip="IP address of the Kronos. Typically 192.168.100.15 over USB, or a DHCP address when connected via a router."/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Stream port" VerticalAlignment="Center"
                                   ToolTip="TCP port the screen-streaming daemon listens on. Default: 7373. Change only if remapped on the Kronos."/>
                        <TextBox   Grid.Row="2" Grid.Column="1" x:Name="TxtStreamPort" Width="80" HorizontalAlignment="Left"
                                   ToolTip="TCP port the screen-streaming daemon listens on. Default: 7373."/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Control port" VerticalAlignment="Center"
                                   ToolTip="TCP port the control daemon listens on (button presses, mode queries). Default: 7374. Change only if remapped on the Kronos."/>
                        <TextBox   Grid.Row="4" Grid.Column="1" x:Name="TxtCtrlPort"  Width="80" HorizontalAlignment="Left"
                                   ToolTip="TCP port the control daemon listens on. Default: 7374."/>
                    </Grid>
                    <TextBlock Margin="0 12 0 0" Foreground="#FF888888" FontSize="11" TextWrapping="Wrap"
                               Text="Connection changes take effect on the next connect. The --host, --port, and --ctrl command-line arguments override these values for the current session only."/>

                    <Border Background="#FF444444" Margin="0 16 0 12" Height="1"/>
                    <TextBlock Text="FTP Credentials" FontWeight="Bold" Foreground="#FF88AADD" Margin="0 0 0 8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="FTP Username" VerticalAlignment="Center"
                                   ToolTip="Username for FTP authentication to the Kronos."/>
                        <TextBox   Grid.Row="0" Grid.Column="1" x:Name="TxtFtpUser"
                                   ToolTip="Username for FTP authentication to the Kronos."/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="FTP Password" VerticalAlignment="Center"
                                   ToolTip="Password for FTP authentication to the Kronos."/>
                        <PasswordBox Grid.Row="2" Grid.Column="1" x:Name="TxtFtpPass"
                                     Background="#FF2A2A2A" Foreground="White" BorderBrush="#FF555555"
                                     Padding="4 2"
                                     ToolTip="Password for FTP authentication to the Kronos."/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="FTP Port" VerticalAlignment="Center"
                                   ToolTip="TCP port for FTP connections to the Kronos. Default: 21."/>
                        <TextBox   Grid.Row="4" Grid.Column="1" x:Name="TxtFtpPort" Width="80" HorizontalAlignment="Left"
                                   ToolTip="TCP port for FTP connections to the Kronos. Default: 21."/>
                    </Grid>
                    <Button x:Name="BtnClearFtp" Content="Clear FTP Credentials"
                            Width="170" HorizontalAlignment="Left" Margin="0 12 0 0"
                            Click="OnClearFtpCredentials"
                            ToolTip="Clear the saved FTP username and password."/>
                    <TextBlock Margin="0 12 0 0" Foreground="#FF888888" FontSize="11" TextWrapping="Wrap"
                               Text="FTP credentials are used for the File Manager and for stream authentication. If left empty, you will be prompted when connecting."/>
                </StackPanel>
            </TabItem>

            <!-- ── Streaming ─────────────────────────────────────────────── -->
            <TabItem Header="Streaming">
                <StackPanel>
                    <TextBlock Text="Stream mode" FontWeight="Bold" Foreground="#FF88AADD" Margin="0 4 0 8"/>
                    <RadioButton x:Name="RbChange" Content="Change-driven — send frames only when the screen changes (recommended)"
                                 Margin="0 0 0 6" GroupName="StreamMode"
                                 ToolTip="Recommended. The daemon sends a frame only when the display changes — uses almost no CPU when the Kronos is idle."/>
                    <RadioButton x:Name="RbPull"   Content="Pull — client requests each frame individually"
                                 GroupName="StreamMode"
                                 ToolTip="The client requests each frame individually. Try this if frames are occasionally missed in change-driven mode."/>

                    <TextBlock Text="Max frame rate" FontWeight="Bold" Foreground="#FF88AADD" Margin="0 18 0 8"/>
                    <DockPanel LastChildFill="True">
                        <TextBlock x:Name="TxtFpsLabel" DockPanel.Dock="Right" Width="50"
                                   VerticalAlignment="Center" TextAlignment="Right"/>
                        <Slider x:Name="SlFps" Minimum="1" Maximum="15"
                                TickFrequency="1" IsSnapToTickEnabled="True"
                                ValueChanged="SlFps_ValueChanged"
                                ToolTip="Maximum frames per second the daemon will deliver. 15 fps matches the Kronos display refresh rate."/>
                    </DockPanel>
                    <TextBlock Margin="0 6 0 0" Foreground="#FF888888" FontSize="11" TextWrapping="Wrap"
                               Text="Change-driven mode consumes no CPU when the Kronos screen is idle. Pull mode may help if frames are occasionally missed. Streaming changes take effect on the next connect."/>

                    <Border Background="#FF444444" Margin="0 18 0 12" Height="1"/>
                    <CheckBox x:Name="ChkDisableBootScreen" Content="Disable boot screen graphics" Margin="0 0 0 6"
                              ToolTip="Suppresses the animated splash overlay shown while the Kronos is booting. The raw boot frames are still displayed — only the decorative overlay is removed."/>
                    <TextBlock Margin="0 0 0 0" Foreground="#FF888888" FontSize="11" TextWrapping="Wrap"
                               Text="When enabled, the animated boot splash overlay is not drawn. You will still see the raw Kronos boot frames as they stream in."/>

                    <TextBlock Text="Boot screen detection" FontWeight="Bold" Foreground="#FF88AADD" Margin="0 18 0 8"/>
                    <DockPanel LastChildFill="True">
                        <TextBlock x:Name="TxtBootThreshLabel" DockPanel.Dock="Right" Width="50"
                                   VerticalAlignment="Center" TextAlignment="Right"/>
                        <Slider x:Name="SlBootThresh" Minimum="10" Maximum="95"
                                TickFrequency="5" IsSnapToTickEnabled="True"
                                ValueChanged="SlBootThresh_ValueChanged"
                                ToolTip="Percentage of black pixels required before the boot splash animation is shown. Raise this if the boot screen appears during normal use (e.g. calibration mode)."/>
                    </DockPanel>
                    <TextBlock Margin="0 6 0 0" Foreground="#FF888888" FontSize="11" TextWrapping="Wrap"
                               Text="Percentage of the frame that must be black before the boot splash overlay is displayed. Raise this value if the splash appears during normal use (e.g. Kronos calibration mode with a dark screen). Default: 60%."/>
                </StackPanel>
            </TabItem>

            <!-- ── View ─────────────────────────────────────────────────── -->
            <TabItem Header="View">
                <StackPanel Margin="0 4 0 0">
                    <TextBlock Text="Zoom" FontWeight="Bold" Foreground="#FF88AADD" Margin="0 0 0 8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Default zoom level (×)" VerticalAlignment="Center"
                                   ToolTip="Zoom multiplier used when zoom is first activated and when reset. Also the minimum — zooming out stops here."/>
                        <Slider    Grid.Column="1" x:Name="SlZoomLevel"
                                   Minimum="2.5" Maximum="5.0"
                                   TickFrequency="0.5" IsSnapToTickEnabled="True"
                                   ValueChanged="SlZoomLevel_ValueChanged"
                                   ToolTip="Zoom multiplier used when zoom is first activated and when reset. Also the minimum — zooming out stops here."/>
                        <TextBlock Grid.Column="2" x:Name="TxtZoomLabel"
                                   VerticalAlignment="Center" Margin="6 0 0 0" TextAlignment="Right"/>
                    </Grid>
                    <TextBlock Margin="0 8 0 0" Foreground="#FF888888" FontSize="11" TextWrapping="Wrap"
                               Text="The zoom level used when zoom is first activated and when it is reset. This is also the minimum — zooming out stops here. Zoom In/Out key bindings are set in the Key Bindings tab."/>

                    <Border Background="#FF444444" Margin="0 16 0 12" Height="1"/>
                    <TextBlock Text="Zoom Tool" FontWeight="Bold" Foreground="#FF88AADD" Margin="0 0 0 8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Tool size" VerticalAlignment="Center"
                                   ToolTip="Size of the zoom loupe overlay. 1× = 200×150 px. Snaps to 0.5× steps; slide freely between snap points."/>
                        <Slider    Grid.Column="1" x:Name="SlZoomWindowSize"
                                   Minimum="1.0" Maximum="3.5"
                                   SmallChange="0.1" LargeChange="0.5"
                                   ValueChanged="SlZoomWindowSize_ValueChanged"
                                   ToolTip="Size of the zoom loupe overlay. 1× = 200×150 px. Snaps to 0.5× steps; slide freely between snap points."/>
                        <TextBlock Grid.Column="2" x:Name="TxtZoomWindowSizeLabel"
                                   VerticalAlignment="Center" Margin="6 0 0 0" TextAlignment="Right"/>
                    </Grid>
                    <TextBlock Margin="0 6 0 0" Foreground="#FF888888" FontSize="11" TextWrapping="Wrap"
                               Text="Size of the zoom window overlay at 1× (200×150 px). Snaps to 1×–3.5× at 0.5× intervals; slide freely between snap points."/>
                </StackPanel>
            </TabItem>

            <!-- ── Key Bindings ──────────────────────────────────────────── -->
            <TabItem Header="Key Bindings">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <ListView x:Name="KeyList" Grid.Row="0"
                              SelectionMode="Single"
                              MouseDoubleClick="OnKeyListDoubleClick"
                              KeyDown="OnKeyListKeyDown"
                              ToolTip="Double-click a row to rebind it. Hold Ctrl/Alt/Shift before pressing the key to set a chord. Press Delete to clear the selected binding. Escape cancels.">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Action" Width="250" DisplayMemberBinding="{Binding Label}"/>
                                <GridViewColumn Header="Key"    Width="160" DisplayMemberBinding="{Binding DisplayKey}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                    <TextBlock Grid.Row="2" Foreground="#FF888888" FontSize="11" TextWrapping="Wrap"
                               Text="Double-click a row to rebind it. Hold Ctrl/Alt/Shift before pressing the key to set a chord. Press Delete to clear the selected binding. Escape cancels."/>
                </Grid>
            </TabItem>

            <!-- ── Macros ────────────────────────────────────────────────── -->
            <TabItem Header="Macros">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" MinHeight="80"/>
                        <RowDefinition Height="1"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- List + toolbar -->
                    <DockPanel Grid.Row="0" Margin="0 4 0 0">
                        <DockPanel DockPanel.Dock="Top" Margin="0 0 0 5" LastChildFill="False">
                            <Button x:Name="BtnMacroAdd"    Content="Add"    Margin="0 0 4 0"
                                    DockPanel.Dock="Left"  Click="OnMacroAdd"
                                    ToolTip="Create a new empty macro."/>
                            <Button x:Name="BtnMacroRemove" Content="Remove" IsEnabled="False"
                                    DockPanel.Dock="Left"  Click="OnMacroRemove"
                                    ToolTip="Delete the selected macro."/>
                            <Button x:Name="BtnMacroPlay"   Content="▶ Play" IsEnabled="False"
                                    DockPanel.Dock="Right" Click="OnMacroPlay"
                                    ToolTip="Play the selected macro once immediately."/>
                        </DockPanel>
                        <ListView x:Name="MacroList" SelectionMode="Single"
                                  SelectionChanged="OnMacroSelectionChanged"
                                  ToolTip="Select a macro to edit its steps, trigger key, and delay below.">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Description" Width="170" DisplayMemberBinding="{Binding Description}"/>
                                    <GridViewColumn Header="Trigger"     Width="110" DisplayMemberBinding="{Binding TriggerDisplay}"/>
                                    <GridViewColumn Header="Steps"       Width="44"  DisplayMemberBinding="{Binding StepCount}"/>
                                    <GridViewColumn Header="Delay"       Width="54"  DisplayMemberBinding="{Binding DelayDisplay}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </DockPanel>

                    <!-- Divider -->
                    <Border Grid.Row="1" Background="#FF444444" Margin="0 6 0 4"/>

                    <!-- Editor panel (disabled until a row is selected) -->
                    <Grid Grid.Row="2" x:Name="MacroEditor" IsEnabled="False">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Row 0: Description -->
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="78"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Description:" VerticalAlignment="Center"
                                       ToolTip="Name shown in the macro list."/>
                            <TextBox   Grid.Column="1" x:Name="TxtMacroDesc" TextChanged="OnMacroDescChanged"
                                       ToolTip="Name shown in the macro list."/>
                        </Grid>

                        <!-- Row 2: Trigger -->
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="78"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Trigger:" VerticalAlignment="Center"
                                       ToolTip="Keyboard shortcut that fires this macro automatically. Must include Ctrl, Alt, or Shift."/>
                            <Button    Grid.Column="1" x:Name="BtnMacroTrigger" Content="(none)"
                                       HorizontalContentAlignment="Left"
                                       Click="OnMacroTriggerClick"
                                       ToolTip="Click, then press a key combination to assign a trigger. Must include Ctrl, Alt, or Shift. Press Escape to cancel."/>
                        </Grid>

                        <!-- Row 4: Step delay slider -->
                        <Grid Grid.Row="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="78"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="48"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Step delay:" VerticalAlignment="Center"
                                       ToolTip="Pause between each key event during macro playback."/>
                            <Slider    Grid.Column="1" x:Name="SlMacroDelay"
                                       Minimum="10" Maximum="500" TickFrequency="10" IsSnapToTickEnabled="True"
                                       ValueChanged="OnMacroDelayChanged"
                                       ToolTip="Pause between each key event during macro playback. Increase if the Kronos misses steps."/>
                            <TextBlock Grid.Column="2" x:Name="TxtMacroDelayLabel"
                                       VerticalAlignment="Center" Margin="6 0 0 0" TextAlignment="Right"/>
                        </Grid>

                        <!-- Row 6: Steps readout -->
                        <TextBox Grid.Row="6" x:Name="TxtMacroSteps"
                                 IsReadOnly="True" TextWrapping="Wrap" Height="44"
                                 Background="#FF1E1E1E" Foreground="#FFBBBBBB"
                                 VerticalScrollBarVisibility="Auto" Padding="3 2"
                                 Text="(no steps recorded)"
                                 ToolTip="The recorded key presses and releases that make up this macro. Read-only — use Record to capture new steps."/>

                        <!-- Row 8: Record / Clear + hint -->
                        <DockPanel Grid.Row="8">
                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                <Button x:Name="BtnMacroRecord" Content="● Record" Width="84" Margin="0 0 6 0"
                                        Click="OnMacroRecordToggle"
                                        ToolTip="Start recording keystrokes as macro steps. Click again (■ Stop) to finish. Replaces any existing steps."/>
                                <Button x:Name="BtnMacroClear"  Content="Clear"    Width="60"
                                        Click="OnMacroClear"
                                        ToolTip="Remove all recorded steps from this macro."/>
                            </StackPanel>
                            <TextBlock VerticalAlignment="Center" Margin="10 0 0 0"
                                       Foreground="#FF666666" FontSize="11" TextWrapping="Wrap"
                                       Text="Best with navigation and control keys. Trigger must include a modifier (Ctrl/Alt/Shift)."/>
                        </DockPanel>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ── Debug ─────────────────────────────────────────────────── -->
            <TabItem Header="Debug">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="1"/>
                        <RowDefinition Height="*" MinHeight="60"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Logging -->
                    <CheckBox Grid.Row="0" x:Name="ChkDebugLogging" Content="Enable debug logging"
                              Margin="0 4 0 10"
                              ToolTip="Writes verbose DEBUG entries to the log file. Takes effect immediately. Enable only when diagnosing issues — it can grow the log quickly."/>
                    <TextBlock Grid.Row="1" Foreground="#FF888888" FontSize="11" TextWrapping="Wrap"
                               Margin="0 0 0 16"
                               Text="When enabled, verbose DEBUG entries are written to the log file. Only Info, Warn, and Error are logged when this is off. Takes effect immediately."/>

                    <!-- Separator -->
                    <Border Grid.Row="2" Background="#FF444444"/>

                    <!-- Keyboard Input Mapping -->
                    <DockPanel Grid.Row="3" Margin="0 12 0 0">
                        <TextBlock DockPanel.Dock="Top"
                                   Text="Keyboard Input Mapping"
                                   FontWeight="Bold" Foreground="#FF88AADD"
                                   Margin="0 0 0 8"/>
                        <DockPanel DockPanel.Dock="Top" LastChildFill="False" Margin="0 0 0 5">
                            <Button x:Name="BtnRawAdd"        Content="Add"         Margin="0 0 4 0"
                                    DockPanel.Dock="Left"  Click="OnRawAdd"
                                    ToolTip="Add a custom mapping from a host key to a Kronos raw keycode."/>
                            <Button x:Name="BtnRawRemove"     Content="Remove"      IsEnabled="False"
                                    DockPanel.Dock="Left"  Click="OnRawRemove"
                                    ToolTip="Remove the selected raw key mapping."/>
                            <Button x:Name="BtnInputTester"   Content="Test Inputs" IsEnabled="False" Visibility="Hidden"
                                    DockPanel.Dock="Right" Click="OnInputTesterClick"/>
                        </DockPanel>
                        <TextBlock DockPanel.Dock="Bottom" Margin="0 6 0 0"
                                   Foreground="#FF888888" FontSize="11" TextWrapping="Wrap"
                                   Text="Custom mappings override the default key map and take effect immediately. Double-click a row to edit it."/>
                        <ListView x:Name="RawList" SelectionMode="Single"
                                  SelectionChanged="OnRawSelectionChanged"
                                  MouseDoubleClick="OnRawDoubleClick"
                                  ToolTip="Custom host-key → Kronos keycode mappings. These override the default key map and apply immediately. Double-click a row to edit it.">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Host Key" Width="100" DisplayMemberBinding="{Binding HostKeyDisplay}"/>
                                    <GridViewColumn Header="→ Sends"  Width="110" DisplayMemberBinding="{Binding RawDisplay}"/>
                                    <GridViewColumn Header="Label"    Width="210" DisplayMemberBinding="{Binding Label}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </DockPanel>

                    <!-- Inline edit panel (collapsed until Add or double-click) -->
                    <Grid Grid.Row="4" x:Name="RawEditor" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="1"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="#FF444444"/>

                        <!-- Label -->
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="76"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Label:" VerticalAlignment="Center"/>
                            <TextBox   Grid.Column="1" x:Name="TxtRawLabel"/>
                        </Grid>

                        <!-- Host key capture -->
                        <Grid Grid.Row="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="76"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Host key:" VerticalAlignment="Center"/>
                            <Button    Grid.Column="1" x:Name="BtnRawCaptureKey" Content="(none)"
                                       HorizontalContentAlignment="Left"
                                       Click="OnRawCaptureKey"/>
                        </Grid>

                        <!-- Raw code + shift -->
                        <Grid Grid.Row="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="76"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Raw code:" VerticalAlignment="Center"/>
                            <TextBox   Grid.Column="1" x:Name="TxtRawCode" Width="55" HorizontalAlignment="Left"/>
                            <CheckBox  Grid.Column="2" x:Name="ChkRawShift" Content="Send Shift"
                                       Margin="12 0 0 0" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Save / Cancel -->
                        <DockPanel Grid.Row="8">
                            <Button x:Name="BtnRawSave"       Content="Save"   Width="60" Margin="0 0 6 0"
                                    DockPanel.Dock="Left" Click="OnRawSave"/>
                            <Button x:Name="BtnRawCancelEdit" Content="Cancel" Width="60"
                                    DockPanel.Dock="Left" Click="OnRawCancelEdit"/>
                        </DockPanel>
                    </Grid>

                </Grid>
            </TabItem>

        </TabControl>

        <!-- Bottom row: Import/Export left, OK/Cancel right -->
        <Grid Grid.Row="2">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button x:Name="BtnExport" Content="Export…" Width="80" Margin="0 0 8 0"
                        Click="OnExport"
                        ToolTip="Save all current settings to a JSON file for backup or sharing."/>
                <Button x:Name="BtnImport" Content="Import…" Width="80"
                        Click="OnImport"
                        ToolTip="Load settings from a JSON file, replacing the current configuration."/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BtnOK"     Content="OK"     Width="80" Margin="0 0 8 0"
                        Click="BtnOK_Click" IsDefault="True"/>
                <Button x:Name="BtnCancel" Content="Cancel" Width="80"
                        Click="BtnCancel_Click" IsCancel="True"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
