<Window x:Class="KronosScreenRemote.SysExToolWindow"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SysEx / MIDI Monitor"
        Width="1600" Height="600"
        MinWidth="600" MinHeight="300"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#FF1A1A1A"
        Foreground="#FFD0D0D0">
    <Window.Resources>
        <Style x:Key="FilterButtonStyle" TargetType="Button">
            <Setter Property="Height"          Value="24"/>
            <Setter Property="MinWidth"        Value="80"/>
            <Setter Property="Padding"         Value="10 0"/>
            <Setter Property="Margin"          Value="3 0"/>
            <Setter Property="FontFamily"      Value="Consolas"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.80"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel>

        <!-- Bottom toolbar -->
        <Border DockPanel.Dock="Bottom" Background="#FF121212"
                BorderBrush="#FF2E2E2E" BorderThickness="0 1 0 0"
                Padding="8 5">
            <DockPanel>
                <Button x:Name="BTN_Clear" Content="Clear" DockPanel.Dock="Left"
                        Width="60" Height="22" Margin="0 0 10 0"
                        Padding="0" FontSize="11"
                        Background="#FF2A2A2A" Foreground="#FFCCCCCC"
                        BorderBrush="#FF444444" BorderThickness="1"
                        Cursor="Hand"/>
                <CheckBox x:Name="CHK_AutoScroll" Content="Auto-scroll"
                          DockPanel.Dock="Left" IsChecked="True"
                          Foreground="#FF888888" FontSize="11"
                          VerticalAlignment="Center" Margin="0 0 12 0"/>
                <TextBlock x:Name="TXT_SysExCount" DockPanel.Dock="Left"
                           Foreground="#FF555555" FontSize="11"
                           VerticalAlignment="Center" Margin="0 0 16 0"/>
                <TextBlock x:Name="TXT_MidiCount" DockPanel.Dock="Left"
                           Foreground="#FF555555" FontSize="11"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Virtual Piano -->
        <Border DockPanel.Dock="Bottom" Background="#FF0D0D0D"
                BorderBrush="#FF2E2E2E" BorderThickness="0 1 0 0"
                Padding="10 11 10 11">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" VerticalAlignment="Center"
                            Width="84" Margin="12 0 0 0">
                    <TextBlock x:Name="TXT_NoteLabel"
                               FontFamily="Consolas" FontSize="13" FontWeight="Bold"
                               Foreground="#FF88AADD"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Virtual Piano"
                               FontFamily="Consolas" FontSize="9"
                               Foreground="#FF444444"
                               HorizontalAlignment="Center"
                               Margin="0 5 0 0"/>
                </StackPanel>
                <Canvas x:Name="PianoCanvas" ClipToBounds="True"/>
            </DockPanel>
        </Border>

        <!-- Filter bar -->
        <Border DockPanel.Dock="Top" Background="#FF191919"
                BorderBrush="#FF2E2E2E" BorderThickness="0 0 0 1"
                Padding="8 5">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Filter:" Foreground="#FF666666" FontSize="11"
                           FontFamily="Consolas" VerticalAlignment="Center"
                           Margin="0 0 8 0"/>
                <Button x:Name="BTN_Filter_Notes"     Content="Notes"      Style="{StaticResource FilterButtonStyle}"/>
                <Button x:Name="BTN_Filter_CC"        Content="CC"         Style="{StaticResource FilterButtonStyle}"/>
                <Button x:Name="BTN_Filter_Prog"      Content="Prog/Bank"  Style="{StaticResource FilterButtonStyle}"/>
                <Button x:Name="BTN_Filter_SysEx"     Content="SysEx"      Style="{StaticResource FilterButtonStyle}"/>
                <Button x:Name="BTN_Filter_Bend"      Content="Pitch Bend" Style="{StaticResource FilterButtonStyle}"/>
                <Button x:Name="BTN_Filter_AfterTouch" Content="AfterTouch" Style="{StaticResource FilterButtonStyle}"/>
                <Button x:Name="BTN_Filter_Transport" Content="Transport"  Style="{StaticResource FilterButtonStyle}"/>
                <TextBlock Foreground="#FF444444" FontSize="10" FontFamily="Consolas"
                           VerticalAlignment="Center" Margin="14 0 0 0"
                           Text="Click: On→Solo→Off"/>
            </StackPanel>
        </Border>

        <!-- Column header -->
        <Border DockPanel.Dock="Top" Background="#FF212121"
                BorderBrush="#FF2E2E2E" BorderThickness="0 0 0 1"
                Padding="6 3">
            <DockPanel>
                <TextBlock Text="Time"    Foreground="#FF666666" FontSize="11" FontFamily="Consolas" Width="82"/>
                <TextBlock Text="Dir"     Foreground="#FF666666" FontSize="11" FontFamily="Consolas" Width="32"/>
                <TextBlock Text="Message" Foreground="#FF666666" FontSize="11" FontFamily="Consolas"/>
            </DockPanel>
        </Border>

        <!-- Unified MIDI + SysEx list -->
        <ListBox x:Name="LB_All"
                 Background="#FF131313"
                 BorderThickness="0"
                 FontFamily="Consolas"
                 FontSize="11"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 VirtualizingPanel.IsVirtualizing="True"
                 VirtualizingPanel.VirtualizationMode="Recycling"
                 SelectionMode="Single">
            <ListBox.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"                   Color="#FF1E3A5A"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}"               Color="#FFFFFFFF"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}"                     Color="#FF131313"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"   Color="#FF1E3A5A"/>
            </ListBox.Resources>
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding"                    Value="6 2"/>
                    <Setter Property="Background"                 Value="Transparent"/>
                    <Setter Property="BorderThickness"            Value="0"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <DockPanel>
                        <TextBlock Text="{Binding Time}" Foreground="#FF555555"
                                   Width="82" DockPanel.Dock="Left"/>
                        <TextBlock Text="{Binding Dir}" Width="32" DockPanel.Dock="Left">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#FF4CAF50"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSend}" Value="True">
                                            <Setter Property="Foreground" Value="#FFAF4C50"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{Binding Hex}" Foreground="{Binding TypeColor}"
                                   TextWrapping="Wrap"/>
                    </DockPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

    </DockPanel>
</Window>
