<Window x:Class="KronosScreenRemote.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About Kronos ScreenRemote"
        Width="400" Height="320"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#FF1A1A1A"
        Foreground="White">
    <Grid Margin="28 24 28 20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="Kronos ScreenRemote"
                   FontSize="22" FontWeight="Bold"
                   Foreground="#FFDDEEFF"/>

        <!-- Subtitle -->
        <TextBlock Grid.Row="1"
                   Text="Remote viewer and control for Korg Kronos"
                   FontSize="12" Foreground="#FF888888"
                   Margin="0 4 0 0"/>

        <!-- Info grid -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Client version"   Foreground="#FF888888" FontSize="12"/>
            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="TXT_ClientVer"  Foreground="#FFD0D0D0" FontSize="12" FontFamily="Consolas"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Client build ID"  Foreground="#FF888888" FontSize="12" Margin="0 4 0 0"/>
            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="TXT_ClientBuild" Foreground="#FFD0D0D0" FontSize="12" FontFamily="Consolas" Margin="0 4 0 0"/>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Daemon version"   Foreground="#FF888888" FontSize="12"/>
            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="TXT_DaemonVer"  Foreground="#FFD0D0D0" FontSize="12" FontFamily="Consolas"/>

            <TextBlock Grid.Row="4" Grid.Column="0" Text="Daemon build ID"  Foreground="#FF888888" FontSize="12" Margin="0 4 0 0"/>
            <TextBlock Grid.Row="4" Grid.Column="1" x:Name="TXT_DaemonBuild" Foreground="#FFD0D0D0" FontSize="12" FontFamily="Consolas" Margin="0 4 0 0"/>
        </Grid>

        <!-- Close button -->
        <Button Grid.Row="5"
                Content="Close"
                HorizontalAlignment="Right"
                Width="80" Height="28"
                Background="#FF3A3A3A" Foreground="White"
                BorderBrush="#FF666666"
                Click="CloseButton_Click"/>
    </Grid>
</Window>
