<Window x:Class="KronosScreenRemote.LoginDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kronos FTP Login" Width="340" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#FF1E1E1E"
        Foreground="White">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background"  Value="#FF2A2A2A"/>
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
            <Setter Property="Padding"     Value="4 2"/>
            <Setter Property="CaretBrush"  Value="White"/>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Background"  Value="#FF2A2A2A"/>
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
            <Setter Property="Padding"     Value="4 2"/>
            <Setter Property="CaretBrush"  Value="White"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background"  Value="#FF3A3A3A"/>
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="BorderBrush" Value="#FF666666"/>
            <Setter Property="Padding"     Value="8 3"/>
            <Setter Property="MinWidth"    Value="75"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="5"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="5"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="6"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Subtitle -->
        <TextBlock Grid.Row="0" x:Name="SubtitleText" Foreground="#FFAAAAAA" FontSize="11"/>

        <!-- Username -->
        <TextBlock Grid.Row="2" Text="Username"/>
        <TextBox   Grid.Row="4" x:Name="TxtUser"/>

        <!-- Password -->
        <TextBlock Grid.Row="6" Text="Password"/>
        <PasswordBox Grid.Row="8" x:Name="PwdBox"/>

        <!-- Save password -->
        <CheckBox Grid.Row="10" x:Name="ChkSave" Content="Save password" IsChecked="True"/>

        <!-- Error -->
        <TextBlock Grid.Row="12" x:Name="ErrorText"
                   Foreground="#FFFF7777" TextWrapping="Wrap"
                   Visibility="Collapsed"/>

        <!-- Buttons -->
        <DockPanel Grid.Row="14">
            <Button x:Name="BtnClear" Content="Clear" Click="OnClear" DockPanel.Dock="Left"
                    ToolTip="Clear both fields so you can enter fresh credentials"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BtnCancel" Content="Cancel" IsCancel="True" Click="OnCancel" Margin="0 0 8 0"/>
                <Button x:Name="BtnOk"    Content="OK"     IsDefault="True" Click="OnOk"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
