<Window x:Class="KronosScreenRemote.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:KronosScreenRemote"
        Title="Kronos ScreenRemote"
        Width="1870" Height="625"
        ResizeMode="CanResize"
        Background="Black"
        Focusable="True"
        Icon="/Resources/Icons/AppIcon.ico">
    <DockPanel>
        <Menu x:Name="MainMenu" DockPanel.Dock="Top">
            <MenuItem x:Name="MENU_Connection" Header="_Connection">
                <MenuItem x:Name="MNU_Reconnect"      Header="_Connect"/>
                <Separator/>

                <MenuItem x:Name="MENU_RecentHosts" Header="_Recent Connections">
                    <MenuItem x:Name="MNU_NoRecentHosts" Header="(none)" IsEnabled="False"/>
                </MenuItem>
                <MenuItem x:Name="MNU_CopyIP" Header="Copy _IP Address"/>
                <Separator/>
                <MenuItem x:Name="MNU_FileManager"    Header="File _Manager…"/>
                <Separator/>
                <MenuItem x:Name="MNU_Disconnect" Header="_Disconnect" IsEnabled="False"/>
                <Separator/>
                <MenuItem x:Name="MNU_Quit"       Header="_Quit"/>
            </MenuItem>
            <MenuItem x:Name="MENU_View" Header="_View">
                <MenuItem x:Name="MNU_AspectLock"    Header="_Aspect Lock"     IsCheckable="True" InputGestureText="A"/>
                <MenuItem x:Name="MNU_Zoom"          Header="_Zoom Window"      IsCheckable="True" InputGestureText="Z"/>
                <Separator/>
                <MenuItem x:Name="MNU_Fullscreen"    Header="_Fullscreen"                          InputGestureText="F"/>
                <MenuItem x:Name="MNU_HideDataInput"  Header="Hide _Data Input"   IsCheckable="True"/>
                <MenuItem x:Name="MNU_HideValueInput" Header="Hide _Value Input"  IsCheckable="True"/>
                <MenuItem x:Name="MNU_AlwaysOnTop"   Header="Always on _Top"   IsCheckable="True"/>
                <MenuItem x:Name="MNU_RefreshDisplay" Header="Re_fresh Display"/>
                <Separator/>
                <MenuItem x:Name="MENU_LayoutPreset" Header="Layout _Preset">
                    <MenuItem x:Name="MNU_PresetFull"    Header="_Full"    IsCheckable="True"
                              ToolTip="Frame + full controls panel (default)"/>
                    <MenuItem x:Name="MNU_PresetFocused" Header="F_ocused" IsCheckable="True"
                              ToolTip="Frame fills window; controls collapse to a narrow rail"/>
                </MenuItem>
                <Separator/>
                <MenuItem x:Name="MENU_WinSize" Header="Window _Size">
                    <MenuItem x:Name="MNU_Size75"  Header="_Small (75%)"        IsCheckable="True" InputGestureText="Ctrl+1"/>
                    <MenuItem x:Name="MNU_Size100" Header="_Normal (100%)"      IsCheckable="True" InputGestureText="Ctrl+2"/>
                    <MenuItem x:Name="MNU_Size125" Header="_Large (125%)"       IsCheckable="True" InputGestureText="Ctrl+3"/>
                    <MenuItem x:Name="MNU_Size150" Header="_Extra Large (150%)" IsCheckable="True" InputGestureText="Ctrl+4"/>
                    <MenuItem x:Name="MNU_Size200" Header="_Huge (200%)"        IsCheckable="True" InputGestureText="Ctrl+5"/>
                </MenuItem>
            </MenuItem>
            <MenuItem x:Name="MENU_Tools" Header="_Tools">
                <MenuItem x:Name="MNU_PaletteEd"  Header="_Palette Editor"        IsCheckable="True" InputGestureText="P"/>
                <MenuItem x:Name="MNU_CalMode"    Header="_Calibration"           IsCheckable="True" InputGestureText="C"/>
                <MenuItem x:Name="MNU_KbdWarp"    Header="Enable _Warp Mode"      IsCheckable="True"/>
                <MenuItem x:Name="MENU_CalGrid"   Header="Calibration _Grid Size">
                    <MenuItem x:Name="MNU_CalGrid3" Header="_3×3" IsCheckable="True"/>
                    <MenuItem x:Name="MNU_CalGrid4" Header="_4×4" IsCheckable="True"/>
                    <MenuItem x:Name="MNU_CalGrid5" Header="_5×5" IsCheckable="True"/>
                </MenuItem>
                <MenuItem x:Name="MNU_TestMode" Header="Enter Kronos _Test Mode"/>
                <Separator/>
                <MenuItem x:Name="MNU_Screenshot"  Header="Save _Screenshot…"     InputGestureText="Ctrl+S"/>
                <MenuItem x:Name="MNU_QuickSave"   Header="_Quick Save Screenshot"/>
                <MenuItem x:Name="MNU_CopyFrame"   Header="_Copy Frame to Clipboard"/>
                <MenuItem x:Name="MNU_OpenScreenshotsFolder" Header="Open Screenshots _Folder"/>
                <MenuItem x:Name="MNU_OpenLog"     Header="Open _Log File"/>
                <Separator/>
                <MenuItem x:Name="MNU_SysExTool"    Header="Open _SysEx Tool…"/>
                <MenuItem x:Name="MNU_KeyboardInfo" Header="_Keyboard Info…"/>
                <MenuItem x:Name="MNU_InputTester"  Header="_Input Tester…" Visibility="Collapsed"/>
                <MenuItem x:Name="MNU_DisableKbd"   Header="_Disable Keyboard Send" IsCheckable="True"/>
            </MenuItem>
            <MenuItem x:Name="MENU_ModeSelect" Header="_Mode Select">
                <MenuItem x:Name="MNU_Mode_Setlist"  Header="_Setlist"/>
                <MenuItem x:Name="MNU_Mode_Combi"    Header="_Combi"/>
                <MenuItem x:Name="MNU_Mode_Program"  Header="_Program"/>
                <MenuItem x:Name="MNU_Mode_Sequence" Header="S_equence"/>
                <MenuItem x:Name="MNU_Mode_Sampling" Header="S_ampling"/>
                <MenuItem x:Name="MNU_Mode_Global"   Header="_Global"/>
                <MenuItem x:Name="MNU_Mode_Disk"     Header="_Disk"/>
            </MenuItem>
            <MenuItem x:Name="MENU_BankSelect" Header="Ban_k Select"/>
            <MenuItem x:Name="MENU_Settings" Header="_Settings">
                <MenuItem x:Name="MNU_SettingsDlg" Header="_Settings…"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem x:Name="MNU_ShowHelp"          Header="_Show Help"            InputGestureText="F1"/>
                <MenuItem x:Name="MNU_CommandPalette"    Header="_Command Palette"      InputGestureText="Ctrl+K"/>
                <Separator/>
                <MenuItem x:Name="MNU_About"             Header="_About…"/>
                <!-- Future: Check for Updates / Report Issue — hidden until a public release pipeline exists -->
                <Separator x:Name="SEP_HelpExternal"    Visibility="Collapsed"/>
                <MenuItem x:Name="MNU_CheckForUpdates"  Header="Check for _Updates…"   Visibility="Collapsed"/>
                <MenuItem x:Name="MNU_ReportIssue"      Header="_Report Issue…"        Visibility="Collapsed"/>
            </MenuItem>
        </Menu>

        <!-- ── Status bar ──────────────────────────────────────────────────── -->
        <StatusBar x:Name="AppStatusBar"
                   DockPanel.Dock="Bottom"
                   Background="#FF1A1A1A"
                   Height="22"
                   Padding="0">
            <!-- Right-aligned items must be declared BEFORE fill items in DockPanel -->
            <StatusBarItem DockPanel.Dock="Right" Padding="4 0 8 0">
                <TextBlock x:Name="ModeText" Foreground="#FF88AADD" FontSize="11"
                           VerticalAlignment="Center"
                           ToolTip="Current Kronos display mode — right-click to change">
                    <TextBlock.ContextMenu>
                        <ContextMenu>
                            <MenuItem x:Name="CTX_Mode_Setlist"  Header="_Setlist"/>
                            <MenuItem x:Name="CTX_Mode_Combi"    Header="_Combi"/>
                            <MenuItem x:Name="CTX_Mode_Program"  Header="_Program"/>
                            <MenuItem x:Name="CTX_Mode_Sequence" Header="S_equence"/>
                            <MenuItem x:Name="CTX_Mode_Sampling" Header="S_ampling"/>
                            <MenuItem x:Name="CTX_Mode_Global"   Header="_Global"/>
                            <MenuItem x:Name="CTX_Mode_Disk"     Header="_Disk"/>
                        </ContextMenu>
                    </TextBlock.ContextMenu>
                </TextBlock>
            </StatusBarItem>
            <Separator DockPanel.Dock="Right" Margin="2 4" Background="#FF444444" Width="1"/>
            <StatusBarItem DockPanel.Dock="Right" Padding="4 0">
                <TextBlock x:Name="ConnModeText" Foreground="#FF666666" FontSize="11"
                           VerticalAlignment="Center"
                           ToolTip="Streaming mode (Pull = server pushes every frame; Change = server pushes on screen change)"/>
            </StatusBarItem>
            <Separator DockPanel.Dock="Right" Margin="2 4" Background="#FF444444" Width="1"/>
            <!-- VU meter -->
            <StatusBarItem DockPanel.Dock="Right" Padding="2 0" VerticalContentAlignment="Center">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <local:VuMeterBar x:Name="VuMeter"
                                      Width="110" Height="14"
                                      Cursor="Hand"
                                      ToolTip="Audio output levels — click to reset clip latch"
                                      Margin="0 0 3 0"/>
                    <ToggleButton x:Name="VuPickerBtn"
                                  Content="▾"
                                  Width="13" Height="13"
                                  Focusable="False"
                                  FocusVisualStyle="{x:Null}"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  Foreground="#FF666666"
                                  FontSize="9"
                                  Padding="0"
                                  VerticalContentAlignment="Center"
                                  HorizontalContentAlignment="Center"
                                  ToolTip="Select audio input device"/>
                    <Popup x:Name="VuPickerPopup"
                           PlacementTarget="{Binding ElementName=VuPickerBtn}"
                           Placement="Top"
                           StaysOpen="False">
                        <Border Background="#FF1E1E1E"
                                BorderBrush="#FF444444"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Audio Input Device"
                                           Padding="8 5 8 3"
                                           Foreground="#FF888888"
                                           FontFamily="Consolas"
                                           FontSize="10"/>
                                <Separator Background="#FF333333" Margin="0"/>
                                <ListBox x:Name="VuDeviceList"
                                         Background="#FF1E1E1E"
                                         Foreground="#FFCCCCCC"
                                         BorderThickness="0"
                                         FontFamily="Consolas"
                                         FontSize="11"
                                         MinWidth="260"
                                         MaxHeight="200"
                                         Padding="0 2"/>
                            </StackPanel>
                        </Border>
                    </Popup>
                </StackPanel>
            </StatusBarItem>
            <Separator DockPanel.Dock="Right" Margin="2 4" Background="#FF444444" Width="1"/>
            <!-- Left items -->
            <StatusBarItem Padding="8 0 4 0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel.ContextMenu>
                        <ContextMenu>
                            <MenuItem x:Name="CTX_StatusReconnect"  Header="_Reconnect"/>
                            <MenuItem x:Name="CTX_StatusDisconnect" Header="_Disconnect"/>
                            <Separator/>
                            <MenuItem x:Name="CTX_StatusCopyIP"     Header="Copy _IP Address"/>
                        </ContextMenu>
                    </StackPanel.ContextMenu>
                    <Ellipse x:Name="StatusDot" Width="12" Height="12" Margin="0 0 6 0"
                             VerticalAlignment="Center" Fill="#FF444444"/>
                    <TextBlock x:Name="StatusText" Foreground="#FF888888" FontSize="11"
                               VerticalAlignment="Center" Text="Not connected"/>
                </StackPanel>
            </StatusBarItem>
            <Separator Margin="2 4" Background="#FF444444" Width="1"/>
            <StatusBarItem Padding="4 0" VerticalContentAlignment="Center">
                <Grid x:Name="KbdStatusGrid" Width="16" Height="13"
                      ToolTip="Keyboard: click screen panel to capture">
                    <Grid.ContextMenu>
                        <ContextMenu>
                            <MenuItem x:Name="CTX_KbdEnable"  Header="_Enable Keyboard Send"/>
                            <MenuItem x:Name="CTX_KbdDisable" Header="_Disable Keyboard Send"/>
                        </ContextMenu>
                    </Grid.ContextMenu>
                    <TextBlock x:Name="KbdStatusIcon" Text="⌨"
                               FontFamily="Segoe UI Symbol" FontSize="11"
                               Foreground="#FF555555"
                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    <Line x:Name="KbdStatusSlash"
                          X1="1" Y1="12" X2="15" Y2="1"
                          Stroke="#FF555555" StrokeThickness="1.5"
                          SnapsToDevicePixels="True"/>
                </Grid>
            </StatusBarItem>
            <Separator Margin="2 4" Background="#FF444444" Width="1"/>
            <StatusBarItem Padding="4 0">
                <TextBlock x:Name="FpsText" Foreground="#FF666666" FontSize="11"
                           VerticalAlignment="Center"
                           ToolTip="Frames per second — right-click to adjust target">
                    <TextBlock.ContextMenu>
                        <ContextMenu>
                            <MenuItem x:Name="CTX_SetMaxFps" Header="Set _Max FPS…"/>
                        </ContextMenu>
                    </TextBlock.ContextMenu>
                </TextBlock>
            </StatusBarItem>
            <Separator Margin="2 4" Background="#FF444444" Width="1"/>
            <StatusBarItem Padding="4 0">
                <TextBlock x:Name="PingText" Foreground="#FF666666" FontSize="11"
                           VerticalAlignment="Center"
                           ToolTip="Round-trip network latency to Kronos"/>
            </StatusBarItem>
            <Separator Margin="2 4" Background="#FF444444" Width="1"/>
            <StatusBarItem Padding="3 0" VerticalContentAlignment="Center">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                            ToolTip="SysEx in/out. Green is received by client, Blue is transmitted from client.">
                    <!-- RX: down-arrow + green dot -->
                    <TextBlock x:Name="SysExRxArrow" Text="↓" FontSize="16"
                               Foreground="#FF2A3A2A" VerticalAlignment="Center"
                               Margin="0 0 1 0" FontFamily="Segoe UI"/>
                    <Ellipse x:Name="SysExRxDot" Width="12" Height="12"
                             Fill="#FF2A3A2A" VerticalAlignment="Center"
                             Margin="0 0 4 0"/>
                    <!-- TX: Red dot + up-arrow -->
                    <Ellipse x:Name="SysExTxDot" Width="12" Height="12"
                             Fill="#FF3A2A2A" VerticalAlignment="Center"
                             Margin="0 0 1 0"/>
                    <TextBlock x:Name="SysExTxArrow" Text="↑" FontSize="16"
                               Foreground="#FF3A2A2A" VerticalAlignment="Center"
                               FontFamily="Segoe UI"/>
                </StackPanel>
            </StatusBarItem>
            <Separator Margin="2 4" Background="#FF444444" Width="1"/>
            <StatusBarItem Padding="2 0" VerticalContentAlignment="Center">
                <!-- Notification bubble: faded gray at rest, red on error.
                     Border with Transparent background keeps the hit area solid. -->
                <Border x:Name="NotifyBubble"
                        Cursor="Hand"
                        Background="Transparent"
                        Padding="2 1"
                        VerticalAlignment="Center"
                        ToolTip="Click to open log">
                    <Border.ContextMenu>
                        <ContextMenu>
                            <MenuItem x:Name="CTX_OpenLogFile"        Header="Open _Log…"/>
                            <MenuItem x:Name="CTX_ClearNotification"  Header="_Clear Notification"/>
                        </ContextMenu>
                    </Border.ContextMenu>
                    <Path x:Name="NotifyBubblePath"
                          Width="14" Height="13"
                          Stretch="Uniform"
                          VerticalAlignment="Center"
                          Fill="#FF3A3A3A"
                          Data="M 1.5,0 L 12,0 Q 14,0 14,2 L 14,8.5 Q 14,10 12,10 L 5.5,10 L 2.5,13 L 3.5,10 L 2,10 Q 0,10 0,8.5 L 0,2 Q 0,0 1.5,0 Z"/>
                </Border>
            </StatusBarItem>
            <Separator Margin="2 4" Background="#FF444444" Width="1"/>
            <StatusBarItem Padding="2 0" VerticalContentAlignment="Center">
                <Border x:Name="KbdInfoBtn"
                        Cursor="Hand"
                        Background="Transparent"
                        Padding="2 1"
                        VerticalAlignment="Center"
                        ToolTip="Keyboard Info">
                    <TextBlock Text="&#xE147;"
                               FontFamily="Segoe UI Symbol"
                               FontSize="18"
                               Foreground="#FF3A3A3A"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>
                </Border>
            </StatusBarItem>
            <Separator Margin="2 4" Background="#FF444444" Width="1"/>
            <StatusBarItem x:Name="PerfStatusBarItem" Padding="4 0">
                <TextBlock Foreground="#FF88AADD" FontSize="11"
                           VerticalAlignment="Center"
                           Text="{Binding PerformanceDisplay}"
                           ToolTip="Current performance — bank, number, and name (via SysEx)"/>
            </StatusBarItem>
        </StatusBar>

        <Grid x:Name="OuterGrid" Background="Black">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="LeftPanelColumn" Width="282*"/>
                <ColumnDefinition x:Name="MainAreaColumn" Width="1600*"/>
            </Grid.ColumnDefinitions>

            <!-- ── Left value-slider panel (column 0) ─────────────────────── -->
            <Grid Grid.Column="0">
                <Viewbox x:Name="LeftPanelViewbox" Stretch="Uniform">
                    <Grid Width="282" Height="600" ClipToBounds="True">
                        <Image Source="/Resources/Images/KronosLeftSide2EMPTY.png"
                               Stretch="Fill"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               SnapsToDevicePixels="False"
                               IsHitTestVisible="False" Margin="-33,-113,-34,0"/>

                        <local:KronosButton x:Name="BTN_Inc"
                            Margin="114,72,118,504"
                            ToolTip="Increment value"
                            UnlitSource="/Resources/Images/UnlitThinButton.png"
                            ButtonMode="None"/>
                        <local:KronosButton x:Name="BTN_Dec"
                            Margin="114,146,118,430"
                            ToolTip="Decrement value"
                            UnlitSource="/Resources/Images/UnlitThinButton.png"
                            ButtonMode="None"/>

                        <Canvas x:Name="ValueSliderCanvas"
                                Margin="87,300,87,30"
                                Background="Transparent"
                                Cursor="Hand">
                            <Image x:Name="ValueSliderThumb"
                                   Width="72" Height="42"
                                   Source="/Resources/Images/Slider.png"
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   Canvas.Left="17" Canvas.Top="228"
                                   IsHitTestVisible="False"/>
                        </Canvas>
                    </Grid>
                </Viewbox>

                <!-- Focused-mode rail: click to expand/collapse value panel -->
                <Border x:Name="ValueRail"
                        Width="28"
                        HorizontalAlignment="Left"
                        Background="#FF1A1A1A"
                        BorderThickness="0 0 1 0"
                        BorderBrush="#FF333333"
                        Visibility="Collapsed">
                    <Button x:Name="BtnValueRailExpand"
                            Background="Transparent"
                            Foreground="#FF88DD88"
                            BorderThickness="0"
                            FontSize="16"
                            Focusable="False"
                            VerticalContentAlignment="Center"
                            HorizontalContentAlignment="Center"
                            FocusVisualStyle="{x:Null}"
                            ToolTip="Expand value input">
                        <TextBlock Text="‹" FontSize="16"/>
                    </Button>
                </Border>
            </Grid>

        <Grid x:Name="RootGrid" Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="173*"/>
                <ColumnDefinition Width="627*"/>
                <ColumnDefinition x:Name="ControlsColumn" Width="800*"/>
            </Grid.ColumnDefinitions>

            <!-- ── Screen area (columns 0+1) ──────────────────────────────── -->
            <Image x:Name="FrameImage"
               Stretch="Fill"
               RenderOptions.BitmapScalingMode="HighQuality"
               SnapsToDevicePixels="False"
               Grid.ColumnSpan="2">
                <Image.ContextMenu>
                    <ContextMenu>
                        <MenuItem x:Name="CTX_CopyFrame"       Header="_Copy Frame to Clipboard"/>
                        <MenuItem x:Name="CTX_QuickSave"       Header="_Quick Save Screenshot"/>
                        <MenuItem x:Name="CTX_Screenshot"      Header="Save _Screenshot…" InputGestureText="Ctrl+S"/>
                        <MenuItem x:Name="CTX_OpenScreenshots" Header="Open Screenshots _Folder"/>
                        <Separator/>
                        <MenuItem x:Name="CTX_ZoomIn"          Header="Zoom _In"/>
                        <MenuItem x:Name="CTX_ZoomOut"         Header="Zoom _Out"/>
                        <MenuItem x:Name="CTX_ZoomReset"       Header="_Reset Zoom"/>
                        <Separator/>
                        <MenuItem x:Name="CTX_AspectLock"      Header="_Aspect Lock"  IsCheckable="True"/>
                        <MenuItem x:Name="CTX_Fullscreen"      Header="_Fullscreen"  IsCheckable="True"/>
                        <Separator/>
                        <MenuItem x:Name="CTX_KeyboardInfo"    Header="_Keyboard Info…"/>
                        <Separator/>
                        <MenuItem x:Name="CTX_Reconnect"       Header="Re_connect"/>
                        <MenuItem x:Name="CTX_Disconnect"      Header="_Disconnect"/>
                    </ContextMenu>
                </Image.ContextMenu>
            </Image>
            <local:OverlayElement x:Name="OverlayLayer"
                              IsHitTestVisible="False"
                              Grid.ColumnSpan="2"/>

            <!-- ── Control surface (column 2) ─────────────────────────────── -->
            <!-- Outer Grid allows the Focused-mode rail to overlay the Viewbox. -->
            <Grid Grid.Column="2">
                <!-- Viewbox scales the fixed 800×600 design space to fill column 2
                     at any zoom level. SetWindowSize keeps column 2 at exactly
                     800:600 ratio, so Uniform never letterboxes. -->
                <Viewbox x:Name="ControlViewbox" Stretch="Uniform">
                    <Grid Width="800" Height="600">

                        <!-- Background image -->
                        <Image x:Name="DataInput"
                           Stretch="Fill"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           SnapsToDevicePixels="False"
                           IsHitTestVisible="False"
                           Source="/Resources/Images/DataEntrySurfaceEmpty.png"/>

                        <!-- ── Mode buttons — confirmed by detection before lighting ──── -->
                        <local:KronosButton x:Name="BTN_Setlist"
                            Margin="87,90,603,483"
                            ToolTip="Setlist mode (F2)"
                            UnlitSource="/Resources/Images/UnlitWideButton.png"
                            LitSource="/Resources/Images/LitWideButton.png"
                            ButtonMode="None" RadioGroup="ModeGroup"/>
                        <local:KronosButton x:Name="BTN_Combi"
                            Margin="289,91,401,482"
                            ToolTip="Combi mode (F3)"
                            UnlitSource="/Resources/Images/UnlitWideButton.png"
                            LitSource="/Resources/Images/LitWideButton.png"
                            ButtonMode="None" RadioGroup="ModeGroup"/>
                        <local:KronosButton x:Name="BTN_Program"
                            Margin="407,91,283,482"
                            ToolTip="Program mode (F4)"
                            UnlitSource="/Resources/Images/UnlitWideButton.png"
                            LitSource="/Resources/Images/LitWideButton.png"
                            ButtonMode="None" RadioGroup="ModeGroup"/>
                        <local:KronosButton x:Name="BTN_Sequence"
                            Margin="522,91,168,482"
                            ToolTip="Sequence mode (F5)"
                            UnlitSource="/Resources/Images/UnlitWideButton.png"
                            LitSource="/Resources/Images/LitWideButton.png"
                            ButtonMode="None" RadioGroup="ModeGroup"/>
                        <local:KronosButton x:Name="BTN_Sampling"
                            Margin="289,169,401,404"
                            ToolTip="Sampling mode (F6)"
                            UnlitSource="/Resources/Images/UnlitWideButton.png"
                            LitSource="/Resources/Images/LitWideButton.png"
                            ButtonMode="None" RadioGroup="ModeGroup"/>
                        <local:KronosButton x:Name="BTN_Global"
                            Margin="407,169,283,404"
                            ToolTip="Global mode (F7)"
                            UnlitSource="/Resources/Images/UnlitWideButton.png"
                            LitSource="/Resources/Images/LitWideButton.png"
                            ButtonMode="None" RadioGroup="ModeGroup"/>
                        <local:KronosButton x:Name="BTN_Disk"
                            Margin="522,169,168,404"
                            ToolTip="Disk mode (F8)"
                            UnlitSource="/Resources/Images/UnlitWideButton.png"
                            LitSource="/Resources/Images/LitWideButton.png"
                            ButtonMode="None" RadioGroup="ModeGroup"/>

                        <!-- ── Thin toggle buttons (Help / Compare) ──────────── -->
                        <local:KronosButton x:Name="BTN_Help"
                            Margin="671,91,79,482"
                            ToolTip="Send HELP button to Kronos (F1)"
                            UnlitSource="/Resources/Images/UnlitThinButton.png"
                            LitSource="/Resources/Images/LitThinButton.png"
                            ButtonMode="Toggle"/>
                        <local:KronosButton x:Name="BTN_Compare"
                            Margin="671,169,79,404"
                            ToolTip="Send COMPARE button to Kronos"
                            UnlitSource="/Resources/Images/UnlitThinButton.png"
                            LitSource="/Resources/Images/LitThinButton.png"
                            ButtonMode="Toggle"/>

                        <!-- ── Number pad — no animation ──────────────────────── -->
                        <local:KronosButton x:Name="BTN_data7"
                            Margin="289,250,401,325"
                            ToolTip="Send 7 to Kronos"
                            UnlitSource="/Resources/Images/UnlitWideButton.png"
                            ButtonMode="None"/>
                        <local:KronosButton x:Name="BTN_data8"
                            Margin="407,250,283,325"
                            ToolTip="Send 8 to Kronos"
                            UnlitSource="/Resources/Images/UnlitWideButton.png"
                            ButtonMode="None"/>
                        <local:KronosButton x:Name="BTN_data9"
                            Margin="522,250,168,325"
                            ToolTip="Send 9 to Kronos"
                            UnlitSource="/Resources/Images/UnlitWideButton.png"
                            ButtonMode="None"/>
                        <local:KronosButton x:Name="BTN_data4"
                            Margin="289,328,401,245"
                            ToolTip="Send 4 to Kronos"
                            UnlitSource="/Resources/Images/UnlitWideButton.png"
                            ButtonMode="None"/>
                        <local:KronosButton x:Name="BTN_data5"
                            Margin="407,328,283,245"
                            ToolTip="Send 5 to Kronos"
                            UnlitSource="/Resources/Images/UnlitWideButton.png"
                            ButtonMode="None"/>
                        <local:KronosButton x:Name="BTN_data6"
                            Margin="524,328,166,245"
                            ToolTip="Send 6 to Kronos"
                            UnlitSource="/Resources/Images/UnlitWideButton.png"
                            ButtonMode="None"/>
                        <local:KronosButton x:Name="BTN_data1"
                            Margin="289,409,401,164"
                            ToolTip="Send 1 to Kronos"
                            UnlitSource="/Resources/Images/UnlitWideButton.png"
                            ButtonMode="None"/>
                        <local:KronosButton x:Name="BTN_data2"
                            Margin="407,409,283,164"
                            ToolTip="Send 2 to Kronos"
                            UnlitSource="/Resources/Images/UnlitWideButton.png"
                            ButtonMode="None"/>
                        <local:KronosButton x:Name="BTN_data3"
                            Margin="524,409,166,164"
                            ToolTip="Send 3 to Kronos"
                            UnlitSource="/Resources/Images/UnlitWideButton.png"
                            ButtonMode="None"/>
                        <local:KronosButton x:Name="BTN_data_dash"
                            Margin="290,489,400,84"
                            ToolTip="Send – (dash) to Kronos"
                            UnlitSource="/Resources/Images/UnlitWideButton.png"
                            ButtonMode="None"/>
                        <local:KronosButton x:Name="BTN_data0"
                            Margin="407,489,283,84"
                            ToolTip="Send 0 to Kronos"
                            UnlitSource="/Resources/Images/UnlitWideButton.png"
                            ButtonMode="None"/>
                        <local:KronosButton x:Name="BTN_data_period"
                            Margin="524,489,166,84"
                            ToolTip="Send . (period) to Kronos"
                            UnlitSource="/Resources/Images/UnlitWideButton.png"
                            ButtonMode="None"/>

                        <!-- ── Exit / Enter — no animation ────────────────────── -->
                        <local:KronosButton x:Name="BTN_Exit"
                            Margin="80,493,603,80"
                            ToolTip="Send EXIT button to Kronos (Esc)"
                            UnlitSource="/Resources/Images/ExitButton.png"
                            ButtonMode="None"/>
                        <local:KronosButton x:Name="BTN_Enter"
                            Margin="639,489,44,84"
                            ToolTip="Send ENTER button to Kronos (Enter)"
                            UnlitSource="/Resources/Images/ExitButton.png"
                            ButtonMode="None"/>

                        <!-- ── Data wheel — drag up/down to scroll ───────────── -->
                        <Image x:Name="Data_Wheel"
                           Margin="41,222,557,160"
                           Source="/Resources/Images/DataWheelTransparent.png"
                           RenderTransformOrigin="0.5,0.5"
                           Cursor="SizeNS"
                           ToolTip="Data wheel — drag up/down or scroll to rotate; Ctrl+scroll to zoom frame">
                            <Image.ContextMenu>
                                <ContextMenu>
                                    <MenuItem x:Name="CTX_WheelSensitivity" Header="_Settings…"/>
                                    <MenuItem x:Name="CTX_WheelReset"       Header="Reset _Animation"/>
                                </ContextMenu>
                            </Image.ContextMenu>
                            <Image.RenderTransform>
                                <RotateTransform x:Name="WheelRotate" Angle="0"/>
                            </Image.RenderTransform>
                        </Image>

                    </Grid>
                </Viewbox>

                <!-- Focused-mode rail: click to restore Full preset -->
                <Border x:Name="ControlRail"
                        Width="28"
                        HorizontalAlignment="Right"
                        Background="#FF1A1A1A"
                        BorderThickness="1 0 0 0"
                        BorderBrush="#FF333333"
                        Visibility="Collapsed">
                    <Button x:Name="BtnRailExpand"
                            Background="Transparent"
                            Foreground="#FF88AADD"
                            BorderThickness="0"
                            FontSize="16"
                            Focusable="False"
                            VerticalContentAlignment="Center"
                            HorizontalContentAlignment="Center"
                            FocusVisualStyle="{x:Null}"
                            ToolTip="Expand data input">
                        <TextBlock Text="›" FontSize="16"/>
                    </Button>
                </Border>
            </Grid>
        </Grid>
        </Grid>
    </DockPanel>
</Window>
