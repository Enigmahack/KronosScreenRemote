<Window x:Class="KronosScreenRemote.InputTesterWindow"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Input Tester — Kronos Keyboard Mapper"
        Width="900" Height="620"
        MinWidth="640" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#FF1E1E1E"
        Foreground="#FFCCCCCC">

    <Window.Resources>

        <!-- Override Aero theming so dark background actually renders -->
        <Style TargetType="Button">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Background"      Value="#FF3A3A3A"/>
            <Setter Property="Foreground"      Value="#FFDDDDDD"/>
            <Setter Property="BorderBrush"     Value="#FF666666"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="8,4"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF505050"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF252525"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"                 Value="#FF252525"/>
            <Setter Property="Foreground"                 Value="#FF888888"/>
            <Setter Property="BorderBrush"                Value="#FF444444"/>
            <Setter Property="BorderThickness"            Value="0,0,0,1"/>
            <Setter Property="Padding"                    Value="4,4"/>
            <Setter Property="SeparatorBrush"             Value="#FF444444"/>
            <Setter Property="FontSize"                   Value="11"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="BorderBrush"     Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="2,0"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background"  Value="Transparent"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="#FF1E1E1E"/>
            <Setter Property="Foreground" Value="#FFCCCCCC"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF252525"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FF2D4A7A"/>
                    <Setter Property="Foreground" Value="#FFFFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#FF111111"/>
        </Style>
    </Window.Resources>

    <DockPanel>

        <!-- Bottom panel -->
        <Border DockPanel.Dock="Bottom"
                BorderBrush="#FF444444" BorderThickness="0,1,0,0"
                Background="#FF1A1A1A" Padding="10,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="7"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Row 0: Observed + Send  |  Raw KEY + host-key capture -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Observed + Send -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Observed: " Foreground="#FF888888" VerticalAlignment="Center"/>
                        <!-- Foreground is dark so text is readable on Aero-rendered light background -->
                        <ComboBox x:Name="CboObserved" Width="200" Margin="0,0,10,0"
                                  IsEditable="True"
                                  IsTextSearchEnabled="False"
                                  Background="#FF2A2A2A" Foreground="#FF111111"
                                  BorderBrush="#FF666666" Padding="3,0"
                                  FontFamily="Consolas" FontSize="14"
                                  VerticalContentAlignment="Center"
                                  DropDownClosed="CboObserved_DropDownClosed"
                                  LostFocus="CboObserved_LostFocus"
                                  PreviewKeyDown="CboObserved_PreviewKeyDown">
                            <ComboBox.ItemContainerStyle>
                                <Style TargetType="ComboBoxItem">
                                    <Setter Property="Foreground" Value="#FF111111"/>
                                </Style>
                            </ComboBox.ItemContainerStyle>
                        </ComboBox>
                        <Button x:Name="BtnSend" Content="Send to Kronos  (F5)"
                                Padding="12,5" IsEnabled="False"
                                Click="BtnSend_Click"/>
                    </StackPanel>

                    <!-- Raw KEY + host key capture -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Raw KEY:" Foreground="#FF888888"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox x:Name="TxtRawCode" Width="50" Text="30"
                                 Background="#FF2A2A2A" Foreground="#FFF0F0F0" CaretBrush="White"
                                 BorderBrush="#FF666666" Padding="4,3"
                                 VerticalContentAlignment="Center" FontFamily="Consolas"/>
                        <CheckBox x:Name="ChkRawShift" Content="Shift"
                                  Foreground="#FFCCCCCC" VerticalAlignment="Center"
                                  Margin="8,0"/>
                        <Button Content="Send Raw" Padding="8,5"
                                Click="BtnSendRaw_Click"/>
                        <Rectangle Width="1" Height="20" Fill="#FF555555" Margin="10,0"/>
                        <TextBlock Text="→ host key:" Foreground="#FF888888"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <!-- Click here then press a key to capture the host key binding -->
                        <TextBox x:Name="TxtHostKey" Width="120"
                                 Background="#FF2A2A2A" Foreground="#FFF0F0F0" CaretBrush="Transparent"
                                 BorderBrush="#FF666666" Padding="4,3"
                                 VerticalContentAlignment="Center" FontFamily="Consolas"
                                 IsReadOnly="True" Text="[click, then press key]"
                                 GotFocus="TxtHostKey_GotFocus"
                                 PreviewKeyDown="TxtHostKey_PreviewKeyDown"/>
                        <Button Content="Add Mapping" Padding="8,5" Margin="6,0,0,0"
                                Click="BtnAddMapping_Click"/>
                    </StackPanel>
                </Grid>

                <!-- Row 2: status + Save/Load -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="TxtStatus" Grid.Column="0"
                               Foreground="#FF888888" FontSize="11"
                               VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="Load Results" Padding="8,4" Margin="0,0,6,0"
                                Click="BtnLoad_Click"/>
                        <Button Content="Save Results" Padding="8,4"
                                Click="BtnSave_Click"/>
                    </StackPanel>
                </Grid>

                <!-- Row 4: Custom key mappings -->
                <Grid Grid.Row="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Custom Key Mappings  (host key → raw keycode sent to Kronos)"
                               Foreground="#FF666666" FontSize="11" Margin="0,0,0,3"/>
                    <DataGrid x:Name="MappingsGrid" Grid.Row="1"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              IsReadOnly="True"
                              MaxHeight="110"
                              SelectionMode="Single"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#FF2A2A2A"
                              VerticalGridLinesBrush="Transparent"
                              Background="#FF1A1A1A"
                              RowBackground="#FF1A1A1A"
                              AlternatingRowBackground="#FF1E1E1E"
                              RowHeight="22"
                              FontFamily="Consolas" FontSize="12"
                              Foreground="#FFCCCCCC"
                              BorderThickness="1"
                              BorderBrush="#FF444444"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Host Key" Binding="{Binding HostKeyDisplay}" Width="130"/>
                            <DataGridTextColumn Header="Sends"    Binding="{Binding RawDisplay}"     Width="120"/>
                            <DataGridTextColumn Header="Label"    Binding="{Binding Label}"          Width="*"/>
                            <DataGridTemplateColumn Header="" Width="28">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="×" Padding="2,0" Margin="2,1"
                                                Background="Transparent"
                                                Foreground="#FFCC4444"
                                                BorderBrush="Transparent"
                                                BorderThickness="0"
                                                Tag="{Binding}"
                                                Click="BtnDeleteMapping_Click"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

            </Grid>
        </Border>

        <!-- Main character grid -->
        <DataGrid x:Name="EntryGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False" CanUserDeleteRows="False"
                  CanUserSortColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single" SelectionUnit="FullRow"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#FF2A2A2A"
                  VerticalGridLinesBrush="Transparent"
                  Background="#FF1E1E1E"
                  RowBackground="#FF1E1E1E"
                  AlternatingRowBackground="#FF212121"
                  RowHeight="24"
                  FontFamily="Consolas" FontSize="13"
                  Foreground="#FFCCCCCC"
                  BorderThickness="0"
                  SelectionChanged="EntryGrid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="" Width="22" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding StatusDot}"
                                       Foreground="{Binding StatusBrush}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       FontSize="10"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Char"               Binding="{Binding Display}"  Width="80"/>
                <DataGridTextColumn Header="Code"               Binding="{Binding CodeHex}"  Width="55"/>
                <DataGridTextColumn Header="Send Sequence"      Binding="{Binding SendSeq}"  Width="*"/>
                <DataGridTextColumn Header="Observed on Kronos" Binding="{Binding Observed}" Width="170"/>
            </DataGrid.Columns>
        </DataGrid>

    </DockPanel>
</Window>
